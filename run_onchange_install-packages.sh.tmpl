{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/zsh

echo "Checking Command Line Tools for Xcode"
xcode-select -p &> /dev/null
if [ $? -ne 0 ]; then
  echo "Command Line Tools for Xcode not found. Installing from softwareupdate…"
  touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress;
  PROD=$(softwareupdate -l | grep "\*.*Command Line" | tail -n 1 | sed 's/^[^C]* //')
  softwareupdate -i "$PROD" --verbose;
else
  echo "Command Line Tools for Xcode have been installed."
fi

if test ! $(which brew); then
   printf '\n\n\eHomebrew not found. Installing Homebrew...'
   /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install.sh)"

   {{ if eq .chezmoi.arch "arm64" }}
     eval "$(/opt/homebrew/bin/brew shellenv)"
   {{ else if eq .chezmoi.arch "amd64" }}
     eval "$(/usr/local/bin/brew shellenv)"
   {{ end }}
else
  printf '\n\nHomebrew found. Continuing...'
fi

printf '\nInstalling Homebrew packages...\n'

brew bundle --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

printf '\nRemoving apps not managed in Chezmoi...\n'

brew bundle cleanup --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

printf '\nLinking apps with keg-only formulae...\n'

{{ range .packages.homebrew.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}

printf '\nInstalling MacAppStore apps...\n'

{{ range .packages.darwin.mas -}}
mas install {{ . | quote }}
{{ end -}}

printf '\nInstalling Bun global packages...\n'

{{ range .packages.bun.global -}}
bun install --global {{ . | quote }}
{{ end -}}

{{- end -}}
{{- if (eq .chezmoi.os "linux") -}}
#!/bin/bash

export PATH="/home/linuxbrew/.linuxbrew/bin:$HOME/.local/bin:$PATH"

echo "Installing packages"

sudo apt update

sudo apt install -y {{ range .packages.linux.apt }}{{ . }} {{ end }}

echo "Installing httpstat..."
curl -fsSL https://raw.githubusercontent.com/reorx/httpstat/master/httpstat.py > /tmp/httpstat
sudo install /tmp/httpstat /usr/local/bin/httpstat
rm /tmp/httpstat

if ! command -v aws &> /dev/null; then
    echo "Installing AWS CLI v2..."
    curl "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o "/tmp/awscliv2.zip"
    unzip -q /tmp/awscliv2.zip -d /tmp
    sudo /tmp/aws/install
    rm -rf /tmp/awscliv2.zip /tmp/aws
else
    echo "AWS CLI already installed"
fi

if ! command -v brew &> /dev/null; then
    echo "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
else
    echo "Homebrew already installed"
fi

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

printf '\nInstalling Homebrew packages...\n'

brew bundle --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.linux.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.linux.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF

printf '\nRemoving Homebrew packages not managed in Chezmoi...\n'

brew bundle cleanup --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.linux.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.linux.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF

printf '\nLinking apps with keg-only formulae...\n'

{{ range .packages.homebrew.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}
{{ range .packages.linux.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}

printf '\nUpdating Neovim plugins...\n'
nvim --headless "+Lazy! sync" +qa 2>/dev/null || echo "Plugin update completed"

printf '\nInstalling Bun global packages...\n'

{{ range .packages.bun.global -}}
bun install --global {{ . | quote }}
{{ end -}}

{{- end }}
