{{- if (or (eq .chezmoi.os "darwin") (and (eq .chezmoi.os "linux") (contains "dev" .chezmoi.hostname))) -}}
#!/bin/zsh

if command -v vp &> /dev/null; then
    echo "vp (vite-plus) is already installed"
    exit 0
fi

echo "Installing vp (vite-plus)..."
curl -fsSL https://vite.plus | bash

{{ end -}}
