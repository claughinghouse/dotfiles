{{- if (eq .chezmoi.os "linux") -}}
#!/bin/bash

cat <<'SCRIPT' | sudo tee /usr/local/bin/sysup > /dev/null
#!/bin/bash
set -euo pipefail

export PATH="$HOME/.bun/bin:/home/linuxbrew/.linuxbrew/bin:$HOME/.local/bin:$PATH"

# sysup is meant to be unattended; ignore shell/env settings that make
# Homebrew ask before installs/upgrades.
unset HOMEBREW_ASK
export HOMEBREW_NO_ASK=1
export NONINTERACTIVE=1

# ── apt ──
printf "\nUpdating apt packages...\n"
sudo apt update
sudo apt upgrade -y
sudo apt autoremove -y
sudo apt clean

# ── Homebrew ──
if ! command -v brew &> /dev/null; then
    printf "\nInstalling Homebrew...\n"
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

printf "\nUpdating Homebrew packages...\n"
brew update
printf "\nTrusting Homebrew taps...\n"
{{ range .packages.linux.taps -}}
brew tap {{ . | quote }} 2>/dev/null || true
brew trust {{ . | quote }} 2>/dev/null || true
{{ end -}}
brew bundle --force --file=/dev/stdin <<EOF
{{ range .packages.linux.taps -}}
tap {{ . | quote }}, trusted: true
{{ end -}}
{{ range .packages.linux.brews -}}
brew {{ . | quote }}, trusted: true
{{ end -}}
EOF
brew upgrade --yes
brew cleanup
brew doctor || true

{{ range .packages.linux.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}

# ── AWS CLI ──
if command -v aws &> /dev/null; then
    printf "\nChecking AWS CLI updates...\n"
    AWS_CURRENT=$(aws --version 2>&1 | grep -Po 'aws-cli/\K[0-9]+\.[0-9]+\.[0-9]+' || true)
    AWS_LATEST=$(curl -s "https://api.github.com/repos/aws/aws-cli/releases/latest" | grep -Po '"tag_name": "\K[^"]*' || true)
    if [ -n "$AWS_CURRENT" ] && [ -n "$AWS_LATEST" ] && [ "$AWS_CURRENT" != "$AWS_LATEST" ]; then
        echo "Updating AWS CLI ${AWS_CURRENT} -> ${AWS_LATEST}..."
        curl "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o "/tmp/awscliv2.zip"
        unzip -q -o /tmp/awscliv2.zip -d /tmp
        sudo /tmp/aws/update
        rm -rf /tmp/awscliv2.zip /tmp/aws
        echo "AWS CLI updated to ${AWS_LATEST}"
    else
        echo "AWS CLI already at latest (${AWS_CURRENT:-unknown})"
    fi
fi

# ── bun global dependencies ──
printf "\nUpdating bun global dependencies...\n"
bun update --global || true

# ── piped installers ──
printf "\nChecking piped installers...\n"

# httpstat
HTTPSTAT_URL="https://raw.githubusercontent.com/reorx/httpstat/master/httpstat.py"
curl -fsSL "${HTTPSTAT_URL}" | sudo tee /usr/local/bin/httpstat > /dev/null
sudo chmod +x /usr/local/bin/httpstat
echo "httpstat updated"

# plannotator
if [ -x "$HOME/.local/bin/plannotator" ]; then
  printf "Updating plannotator...\n"
  curl -fsSL https://plannotator.ai/install.sh | bash -s -- --non-interactive
fi

# vp (vite-plus)
if command -v vp &> /dev/null; then
  printf "Upgrading vp (vite-plus)...\n"
  vp upgrade
fi

# pi coding agent
if command -v pi &> /dev/null; then
  printf "Updating pi coding agent...\n"
  pi update
fi

# ── oh-my-zsh ──
if [ -d "$HOME/.oh-my-zsh" ]; then
    printf "\nUpdating oh-my-zsh...\n"
    ZSH="$HOME/.oh-my-zsh" zsh -c 'source $ZSH/tools/upgrade.sh' 2>/dev/null || true
fi

printf "\n✓ System update complete\n"
SCRIPT

sudo chmod +x /usr/local/bin/sysup

{{ end -}}
