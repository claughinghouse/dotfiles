export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="dracula-pro"

zstyle ':omz:update' mode auto      # update automatically without asking
zstyle ':omz:update' frequency 13

# Uncomment the following line to enable command auto-correction.
# ENABLE_CORRECTION="true"

plugins=(colorize cp direnv gh git git-prompt httpie kubectl mosh tmux transfer composer)

source $ZSH/oh-my-zsh.sh
RPROMPT=
export EDITOR=nvim
export ZSH_THEME_GIT_PROMPT_CACHE=yes

# User configuration

{{ if eq .chezmoi.os "linux" }}
# Ensure locally-installed tools are on PATH
export PATH="$HOME/.local/bin:$PATH"
PROMPT="%m ${PROMPT}"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# bun completions
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# go
export GOPATH=$HOME/go
export PATH="$PATH:$HOME/go/bin"
{{ end }}

alias k=kubectl
alias n=nvim
alias n.="nvim ."
alias c=chezmoi
alias t=tmux
alias sail='sh $([ -f sail ] && echo sail || echo vendor/bin/sail)'
alias ar="php artisan"

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# {{ if (eq .chezmoi.hostname "dev") }}
# if command -v tmux &> /dev/null && [ -z "$TMUX" ]; then
#    tmux attach -d || tmux new
#fi
#{{ end }}

{{- if (eq .chezmoi.os "darwin" )}}
# Homebrew on PATH (for predictable ordering)
export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH"

# Updated SQLite3
export PATH="/usr/local/opt/sqlite/bin:$PATH"
export PATH="$HOME/.bun/bin:$PATH"
source <(fzf --zsh)

# set gopath
export PATH=$PATH:$(go env GOPATH)/bin

# Set composer global bin path
export COMPOSER_HOME="$HOME/.config/composer";

# Podman shim for wrangler (replaces docker CLI)
export PATH="$HOME/bin:$PATH"
export WRANGLER_DOCKER_BIN=docker
export WRANGLER_DOCKER_HOST="unix://$(podman info --format '{{ "{{" }}.Host.RemoteSocket.Path{{ "}}" }}' 2>/dev/null)"

{{- end }}
typeset -U PATH
