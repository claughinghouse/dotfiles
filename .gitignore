.DS_Store
.DS_STORE
lazy-lock.json
.envrc
backups/
tmp/

# Python
__pycache__/
*.pyc

# jj
.jj

# pi agent runtime/state (keep settings + customization resources tracked)
dot_pi/agent/*
dot_pi/todos/*
dot_pi/dot_pi/todos/*
.pi/todos/*

# pi secrets/auth/runtime caches
dot_pi/node_modules/
dot_pi/agent/auth.json
dot_pi/agent/mcp-auth/
dot_pi/agent/mcp-oauth/
dot_pi/agent/mcp-cache.json
dot_pi/agent/mcp-npx-cache.json
dot_pi/agent/mcp-auth.json
dot_pi/agent/sessions/
dot_pi/agent/npm/
dot_local/share/pi/mcp-auth.json

# pi config/customization allowed in git
!dot_pi/agent/mcp.json
!dot_pi/agent/settings.json
!dot_pi/agent/tsconfig.json
!dot_pi/agent/package.json
!dot_pi/agent/cloak.json
!dot_pi/agent/APPEND_SYSTEM.md
!dot_pi/agent/symlink_skills.tmpl
!dot_pi/agent/npm/
!dot_pi/agent/npm/dot_gitignore
!dot_pi/agent/themes/
!dot_pi/agent/themes/*.json
!dot_pi/agent/extensions/
!dot_pi/agent/extensions/**

# pi exclusions after broad customization unignore
dot_pi/agent/extensions/**/node_modules/
