alias c clear
alias k kubectl
alias n nvim
alias n. 'nvim .'
alias t tmux
alias ta 'tmux attach'

# Protect npm package installs with Socket Firewall.
alias npm 'sfw npm'

alias code vim
alias grep 'grep --color=auto --exclude-dir={.bzr,CVS,.git,.hg,.svn,.idea,.tox}'
alias ks 'tmux kill-server'
alias pbc pbcopy
alias pbp pbpaste
alias pn pnpm
alias scratch 'nvim -c "setlocal buftype=nofile"'
alias vimdiff 'nvim -d'
alias wr wrangler
