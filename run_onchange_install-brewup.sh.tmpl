{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/zsh

cat <<EOF | sudo tee /usr/local/bin/brewup > /dev/null
#!/bin/bash
# Update homebrew, and local base of available packages and versions
printf "Updating homebrew and local base of available packages and versions...\n"
brew update

# Install new versions of outdated packages
printf "Upgrading outdated homebrew packages...\n"
brew upgrade

# Cache cleanup of unfinished downloads
printf "Cleaning cache of unfinished downloads...\n"
brew cleanup

# Show problems if any
printf "Checking for issues...\n"
brew doctor

# Update bun global dependencies
# NOTE: Moving away from bun for global tool install. Using aube and mise instead.
# printf "Updating bun global dependencies...\n"
# bun update --global

# Update mise global tools
printf "Updating mise global tools...\n"
mise upgrade -y

# Update plannotator if installed (check direct path since ~/.local/bin may not be in PATH)
if [ -x "$HOME/.local/bin/plannotator" ]; then
  printf "Updating plannotator...\n"
  curl -fsSL https://plannotator.ai/install.sh | bash
fi
EOF

sudo chmod +x /usr/local/bin/brewup

{{ end -}}
