{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/zsh

cat <<'SCRIPT' | sudo tee /usr/local/bin/brewup > /dev/null
#!/bin/zsh
set -e

{{- if eq .chezmoi.arch "arm64" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- else if eq .chezmoi.arch "amd64" }}
eval "$(/usr/local/bin/brew shellenv)"
{{- end }}

printf "Updating Homebrew package definitions...\n"
brew update

printf "Installing/updating Homebrew packages managed by Chezmoi...\n"
brew bundle --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

printf "Upgrading outdated Homebrew packages...\n"
brew upgrade

printf "Cleaning up Homebrew...\n"
brew cleanup

printf "Checking Homebrew for issues...\n"
brew doctor || true

{{ range .packages.homebrew.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}

printf "Updating bun global dependencies...\n"
bun update --global

if [ -x "$HOME/.local/bin/plannotator" ]; then
  printf "Updating plannotator...\n"
  curl -fsSL https://plannotator.ai/install.sh | bash
fi

if command -v vp &> /dev/null; then
  printf "Updating vp (vite-plus)...\n"
  vp update
fi
SCRIPT

sudo chmod +x /usr/local/bin/brewup

{{- else if (eq .chezmoi.os "linux") -}}
#!/bin/bash

cat <<'SCRIPT' | sudo tee /usr/local/bin/brewup > /dev/null
#!/bin/bash
set -euo pipefail

export PATH="/home/linuxbrew/.linuxbrew/bin:$HOME/.local/bin:$PATH"

if ! command -v brew &> /dev/null; then
  printf "Installing Homebrew...\n"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

printf "Updating Homebrew package definitions...\n"
brew update

printf "Installing/updating Homebrew packages managed by Chezmoi...\n"
brew bundle --force --file=/dev/stdin <<EOF
{{ range .packages.homebrew.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.linux.taps -}}
tap {{ . | quote }}
{{ end -}}
{{ range .packages.homebrew.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.linux.brews -}}
brew {{ . | quote }}
{{ end -}}
EOF

printf "Upgrading outdated Homebrew packages...\n"
brew upgrade

printf "Cleaning up Homebrew...\n"
brew cleanup

printf "Checking Homebrew for issues...\n"
brew doctor || true

{{ range .packages.homebrew.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}
{{ range .packages.linux.brewlink -}}
brew link --force {{ . | quote }}
{{ end -}}

printf "Updating bun global dependencies...\n"
bun update --global

if [ -x "$HOME/.local/bin/plannotator" ]; then
  printf "Updating plannotator...\n"
  curl -fsSL https://plannotator.ai/install.sh | bash
fi

if command -v vp &> /dev/null; then
  printf "Updating vp (vite-plus)...\n"
  vp update
fi
SCRIPT

sudo chmod +x /usr/local/bin/brewup
{{- end -}}
