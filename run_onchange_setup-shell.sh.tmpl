{{- if (eq .chezmoi.os "darwin") -}}
#!/bin/zsh
{{- else -}}
#!/bin/bash
{{- end }}

set -euo pipefail

{{- if eq .chezmoi.os "linux" }}
export PATH="/home/linuxbrew/.linuxbrew/bin:$PATH"
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi
{{- end }}

fish_path="$(command -v fish)"

{{- if eq .chezmoi.os "darwin" }}
current_shell="$(dscl . -read "/Users/$(id -un)" UserShell 2>/dev/null | awk '{print $2}')"
{{- else }}
current_shell="$(getent passwd "$(id -un)" | cut -d: -f7)"
{{- end }}
current_shell="${current_shell:-${SHELL:-}}"

resolve_path() {
    if command -v realpath >/dev/null 2>&1; then
        realpath "$1"
    else
        readlink -f "$1" 2>/dev/null || printf '%s\n' "$1"
    fi
}

if [ "$(resolve_path "$current_shell")" = "$(resolve_path "$fish_path")" ]; then
    echo "Default shell is already fish."
    exit 0
fi

echo "Changing default shell to fish..."
if ! grep -qxF "$fish_path" /etc/shells; then
    echo "Adding fish to /etc/shells..."
    echo "$fish_path" | sudo tee -a /etc/shells > /dev/null
fi
chsh -s "$fish_path"
echo "Default shell changed to fish. Please log out and log back in for changes to take effect."
